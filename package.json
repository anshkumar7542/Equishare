{
  "name": "equishare",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.9.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:server": "pnpm --filter equishare-server dev",
    "dev:client": "pnpm --filter equishare-client dev",
    "build": "pnpm --filter equishare-client build && pnpm --filter equishare-server build",
    "start": "pnpm --filter equishare-server start",
    "test": "pnpm --filter equishare-server test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "prisma migrate reset",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }

}
